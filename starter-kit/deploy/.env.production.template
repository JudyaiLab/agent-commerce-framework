# AgenticTrade Starter Kit — Environment Variables
# Copy to .env and fill in your values

# ─── AgenticTrade Marketplace ───
# The hosted marketplace URL (default: production)
ACF_MARKETPLACE_URL=https://agentictrade.io

# Your API key from the marketplace (get one at https://agentictrade.io/api-docs)
ACF_API_KEY=

# ─── Your Agent Service ───
# Port your agent API runs on
PORT=8080

# ─── Payment: NOWPayments (Crypto) ───
# Only needed if you run your own marketplace instance
# Get keys at https://nowpayments.io/
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ─── Payment: x402 / AgentKit (On-chain USDC) ───
# USDC wallet address on Base network (for receiving payouts)
WALLET_ADDRESS=

# ─── SSL ───
# Your domain for SSL certificate
DOMAIN=yourdomain.com
